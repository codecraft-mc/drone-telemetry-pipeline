# Required: PostgreSQL connection string for `pg`
DATABASE_URL=postgresql://telemetry:telemetry@localhost:5432/telemetry

# Required: Redis connection URL for `ioredis`
REDIS_URL=redis://localhost:6379

# Optional: defaults to `development` if unset
NODE_ENV=development

# Optional: Pino log level; defaults to `info` if unset
LOG_LEVEL=info
